    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vite": "^7.0.7",
    "vitest": "^3.2.4"
  }
